# =============================================================================
# DATABASE - Supabase Session Pooler (puerto 5432)
# Formato: postgresql+psycopg2://postgres.[project-ref]:[db-password]@aws-0-[aws-region].pooler.supabase.com:5432/postgres
# Obtenlo en: Supabase Dashboard > Connect > Session pooler
# =============================================================================
DATABASE_URL=postgresql+psycopg2://postgres.[project-ref]:[db-password]@aws-0-[aws-region].pooler.supabase.com:5432/postgres

# =============================================================================
# JWT - Cambia JWT_SECRET_KEY por un valor seguro (mínimo 32 caracteres)
# Genera uno con: python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================
JWT_SECRET_KEY=change-this-to-a-secure-random-string-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# ADMIN - Clave secreta para endpoints administrativos (X-Admin-Key header)
# Genera uno con: python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================
ADMIN_API_KEY=change-this-to-a-secure-admin-key

# =============================================================================
# APP
# =============================================================================
APP_NAME=Transactional Service - Realtors API
APP_VERSION=1.0.0
DEBUG=False

# =============================================================================
# AZURE OPENAI - Necesario para generación de scripts vía LangChain
# =============================================================================
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# =============================================================================
# AZURE BLOB STORAGE - Para subir imágenes de referencia
# El contenedor debe existir previamente con acceso de lectura blob
# =============================================================================
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=reference-images
